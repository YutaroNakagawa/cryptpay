# ============================================================================
# クリプトペイ 環境変数テンプレート
# .env にコピーして値を埋めてください
# ============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Prisma) ---
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- NOWPayments ---
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret-key
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# --- App ---
# 本番デプロイ時は実際のドメインに変更すること（Webhook URL に使用）
# 例: https://pay.your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Platform Fee (%) ---
# 決済1件あたりのプラットフォーム手数料率（例: 3.5 = 3.5%）
PLATFORM_FEE_RATE=3.5

# 出金1件あたりの固定手数料（法定通貨単位。例: 500 = 500円）
WITHDRAWAL_FEE_FIXED=500

# --- Admin ---
# 加盟店登録 API (/api/merchants) を保護するためのシークレットキー
# openssl rand -hex 32 などで生成した長くランダムな文字列を使用すること
ADMIN_API_KEY=your-secret-admin-key

# --- Demo Mode ---
# true にするとデモ完了ボタンが表示され、NOWPayments API 未設定でも動作する
# 本番デプロイ時は必ず false にするか、この行を削除すること
NEXT_PUBLIC_DEMO_MODE=false
# サーバーサイドのデモモード（NOWPayments API 呼び出しをモックに置き換え）
DEMO_MODE=false
